generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN_PROVINSI
  ADMIN_KABKOTA
  ENUMERATOR
}

enum KabupatenKota {
  KOTA_PALU
  DONGGALA
  SIGI
  PARIGI_MOUTONG
  POSO
  TOJO_UNA_UNA
  MOROWALI
  MOROWALI_UTARA
  BANGGAI
  BANGGAI_KEPULAUAN
  BANGGAI_LAUT
  BUOL
  TOLITOLI
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusWawancara {
  BELUM_DIWAWANCARA
  SUDAH_DIWAWANCARA
}

enum JenisPertanyaan {
  PILIHAN_TUNGGAL
  MULTI_PILIHAN
}

model User {
  id            Int            @id @default(autoincrement())
  nama          String
  username      String         @unique
  nomorHp       String?
  wilayahTugas  String? 
  password      String
  tokenVersion  Int            @default(0)
  role          Role
  kabupatenKota KabupatenKota?
  aktif         Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  uploadedWarga     Warga[]
  wargaDiwawancarai Warga[] @relation("WawancaraOleh")

  @@index([role])
  @@index([kabupatenKota])
  @@map("user")
}

model Warga {
  id                        Int             @id @default(autoincrement())
  kabupatenKota             KabupatenKota
  kecamatan                 String
  desaKelurahan             String
  alamat                    String?
  rw                        String?
  rt                        String?
  desilTerbaru              String?
  nomorKK                   String
  nik                       String          @unique
  nama                      String
  jenisKelamin              JenisKelamin?
  tanggalLahir              DateTime?
  tempatLahir               String?
  statusPerkawinan          String?
  hubunganKeluarga          String?
  keberadaanAnggotaKeluarga String?
  disabilitas               String?
  keteranganDisabilitas     String?
  pbiJk                     String?
  bansosPkh                 String?
  bansosSembako             String?

  statusWawancara   StatusWawancara @default(BELUM_DIWAWANCARA)
  tanggalWawancara  DateTime?
  diwawancaraOlehId Int?
  klasifikasi       String? 
  skorSurvei        Int? 
  skorMaksimal      Int?
  latitude          Float?
  longitude         Float? 

  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy       User? @relation(fields: [createdById], references: [id])
  diwawancaraOleh User? @relation("WawancaraOleh", fields: [diwawancaraOlehId], references: [id])
  jawabanWawancara JawabanWawancara[]

  @@index([kabupatenKota])
  @@index([statusWawancara])
  @@map("warga")
}

model BlokWawancara {
  id     Int    @id @default(autoincrement())
  kode   String @unique // "D"
  judul  String // "Karakteristik Responden & Rumah Tangga"
  urutan Int    @default(0)

  pertanyaan PertanyaanWawancara[]

  @@map("blok_wawancara")
}

model PertanyaanWawancara {
  id       Int             @id @default(autoincrement())
  blokId   Int
  kode     String 
  variabel String
  jenis    JenisPertanyaan
  wajib    Boolean         @default(false)
  aturan   String?
  urutan   Int             @default(0)

  blok BlokWawancara @relation(fields: [blokId], references: [id])
  opsi OpsiJawaban[]
  jawaban JawabanWawancara[]

  @@unique([blokId, kode])
  @@map("pertanyaan_wawancara")
}

model OpsiJawaban {
  id           Int    @id @default(autoincrement())
  pertanyaanId Int
  kode         String 
  label        String
  urutan       Int    @default(0)

  pertanyaan PertanyaanWawancara @relation(fields: [pertanyaanId], references: [id])
  jawabanDipilih JawabanOpsiDipilih[]

  @@unique([pertanyaanId, kode])
  @@map("opsi_jawaban")
}

model JawabanWawancara {
  id           Int      @id @default(autoincrement())
  wargaId      Int
  pertanyaanId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  warga       Warga               @relation(fields: [wargaId], references: [id])
  pertanyaan  PertanyaanWawancara @relation(fields: [pertanyaanId], references: [id])
  opsiDipilih JawabanOpsiDipilih[]

  @@unique([wargaId, pertanyaanId])
  @@map("jawaban_wawancara")
}

model JawabanOpsiDipilih {
  id        Int @id @default(autoincrement())
  jawabanId Int
  opsiId    Int

  jawaban JawabanWawancara @relation(fields: [jawabanId], references: [id])
  opsi    OpsiJawaban      @relation(fields: [opsiId], references: [id])

  @@unique([jawabanId, opsiId])
  @@map("jawaban_opsi_dipilih")
}